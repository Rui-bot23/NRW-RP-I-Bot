# ── Discord ────────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here
CLIENT_ID=your_discord_client_id_here
GUILD_ID=your_discord_guild_id_here
DEVELOPER_ID=your_discord_user_id_here

# ── Database ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://youruser:yourpassword@cluster0.xxxxx.mongodb.net/nrwrp

# ── Dashboard ──────────────────────────────────────────────────────────────────
DASHBOARD_ENABLED=true
DASHBOARD_PORT=3000
DASHBOARD_BASE_URL=https://your-app.railway.app
DASHBOARD_SECRET=change-this-to-a-random-string
DISCORD_CLIENT_SECRET=your_discord_oauth_client_secret

# ── Runtime ────────────────────────────────────────────────────────────────────
NODE_ENV=production
